$TTL    604800
@       IN      SOA     ns1.equipoa.local.      admin.equipoa.local. (
                                       2 ; Serial
                                  604800 ; Refresh
                                   86400 ; Retry
                                 2419200 ; Expire
                                604800 ) ; Negative Cache TTL
;
; Name Servers
@       IN      NS      ns1.equipoa.local.
ns1     IN      A       200.1.6.5       ; Cambiar a la IP exacta de este contenedor DNS

; ZONA 1 (Proxy)
proxy   IN      A       200.1.6.2       ; Cambiar a la IP del contenedor Nginx de Z1

; ZONA 2 (DMZ)
juice   IN      A       10.1.2.2        ; Cambiar a IP de juice-shop
webdmz  IN      A       10.1.2.3        ; Cambiar a IP de pure-ftpd anónimo
ftp     IN      A       10.1.2.4        ; Cambiar a IP Apache

; ZONA 3 (App)
dvwa    IN      A       10.2.3.2        ;
webgoat IN      a       10.2.3.3        ;
ftp_aut IN      A       10.2.3.4        ;
ad      IN      A       10.2.3.5        ; Samba AD Controller