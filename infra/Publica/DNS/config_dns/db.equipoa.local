$TTL    604800
@       IN      SOA     ns1.equipoa.local.      admin.equipoa.local. (
                                       4 ; Serial
                                  604800 ; Refresh
                                   86400 ; Retry
                                 2419200 ; Expire
                                604800 ) ; Negative Cache TTL
;
; Name Servers
@       IN      NS      ns1.equipoa.local.
ns1     IN      A       200.1.6.2

; ZONA 1 (Proxy)
proxy   IN      A       200.1.6.3

; Publicación NAT de servicios DMZ (VIPs)
webgoat-pub IN   A       200.1.6.10
webdmz-pub  IN   A       200.1.6.11
ftp-pub     IN   A       200.1.6.12

; ZONA 2 (DMZ)
webgoat IN      A       10.1.2.2
webdmz  IN      A       10.1.2.3
ftp     IN      A       10.1.2.4

; ZONA 3 (App)
dvwa        IN      A       10.2.3.2
webgoatint  IN      A       10.2.3.3
ftp_aut     IN      A       10.2.3.4
ad          IN      A       10.2.3.5